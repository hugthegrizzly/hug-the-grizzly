{
	"name": "move-file",
	"version": "4.1.0",
	"description": "Move a file, directory, or symlink - Even works across devices",
	"license": "MIT",
	"repository": "sindresorhus/move-file",
	"funding": "https://github.com/sponsors/sindresorhus",
	"author": {
		"name": "Sindre Sorhus",
		"email": "sindresorhus@gmail.com",
		"url": "https://sindresorhus.com"
	},
	"type": "module",
	"exports": {
		"types": "./index.d.ts",
		"default": "./index.js"
	},
	"sideEffects": false,
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"test": "xo && ava && tsd"
	},
	"files": [
		"index.js",
		"index.d.ts"
	],
	"keywords": [
		"move",
		"file",
		"directory",
		"folder",
		"symlink",
		"mv",
		"fs",
		"file-system",
		"devices",
		"partitions"
	],
	"devDependencies": {
		"@types/node": "^25.0.10",
		"ava": "^6.4.1",
		"sinon": "^21.0.1",
		"temp-write": "^6.0.0",
		"tempy": "^3.1.2",
		"tsd": "^0.33.0",
		"xo": "^1.2.3"
	},
	"xo": {
		"rules": {
			"no-bitwise": "off"
		}
	}
}
